#!/usr/bin/env bash
set -Eeuo pipefail

step="5%25"

case "${1:-}" in
  up)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ "${step}+" || pactl set-sink-volume @DEFAULT_SINK@ "+5%"
    ;;
  down)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ "${step}-" || pactl set-sink-volume @DEFAULT_SINK@ "-5%"
    ;;
  mute)
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle || pactl set-sink-mute @DEFAULT_SINK@ toggle
    ;;
  *)
    printf 'Usage: %s {up|down|mute}\n' "$0" >&2
    exit 1
    ;;
esac

